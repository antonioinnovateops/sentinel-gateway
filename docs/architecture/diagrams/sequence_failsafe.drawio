<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-17" type="device">
  <diagram id="seq-failsafe" name="Fail-Safe Recovery Sequence">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Fail-Safe and Recovery Sequence" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="linux_box" value="Linux Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="50" width="150" height="40" as="geometry" />
        </mxCell>

        <mxCell id="mcu_box" value="MCU (STM32U575)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Communication loss zone -->
        <mxCell id="loss_zone" value="COMMUNICATION LOSS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;verticalAlign=top;align=center;spacingTop=2;fillOpacity=20;" vertex="1" parent="1">
          <mxGeometry x="50" y="110" width="850" height="50" as="geometry" />
        </mxCell>

        <!-- t=0 -->
        <mxCell id="t0_l" value="t=0: Last heartbeat received" style="text;html=1;fontSize=9;fontStyle=2;align=right;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="10" y="175" width="175" height="20" as="geometry" />
        </mxCell>

        <!-- t=3s MCU side -->
        <mxCell id="t3_mcu" value="t=3s: No Linux messages&#10;ENTER FAILSAFE&#10;All actuators to 0%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="200" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- t=3s Linux side -->
        <mxCell id="t3_linux" value="t=3s: 3 missed heartbeats&#10;Log COMM_LOSS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- MCU sends failsafe health -->
        <mxCell id="m_health" style="rounded=0;strokeColor=#b85450;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="260" as="sourcePoint" /><mxPoint x="195" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m_health_l" value="HealthStatus: state=FAILSAFE, cause=COMM_LOSS" style="edgeLabel;html=1;fontSize=9;fontColor=#b85450;" vertex="1" connectable="0" parent="m_health">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- t=5s Linux recovery -->
        <mxCell id="t5_linux" value="t=5s: Attempt recovery&#10;USB power cycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="290" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- USB reset -->
        <mxCell id="usb_reset" style="rounded=0;strokeColor=#9673a6;strokeWidth=2;flowAnimation=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="195" y="345" as="sourcePoint" /><mxPoint x="720" y="345" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="usb_reset_l" value="USB Power Cycle (QEMU monitor)" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontColor=#9673a6;" vertex="1" connectable="0" parent="usb_reset">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- MCU reboot -->
        <mxCell id="mcu_reboot" value="MCU RESET&#10;Boot to safe state&#10;PWM = 0%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="360" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- USB re-enumerate -->
        <mxCell id="usb_enum" style="rounded=0;strokeColor=#6c8ebf;strokeWidth=2;flowAnimation=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="425" as="sourcePoint" /><mxPoint x="195" y="425" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="usb_enum_l" value="USB CDC-ECM re-enumerated" style="edgeLabel;html=1;fontSize=9;fontColor=#6c8ebf;" vertex="1" connectable="0" parent="usb_enum">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- TCP reconnect -->
        <mxCell id="tcp_reconn" style="rounded=0;strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="195" y="460" as="sourcePoint" /><mxPoint x="720" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tcp_reconn_l" value="TCP reconnect + StateSyncRequest" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontColor=#82b366;" vertex="1" connectable="0" parent="tcp_reconn">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- State sync response -->
        <mxCell id="sync_resp" style="rounded=0;strokeColor=#82b366;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="490" as="sourcePoint" /><mxPoint x="195" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sync_resp_l" value="StateSyncResponse (full state)" style="edgeLabel;html=1;fontSize=9;fontColor=#82b366;" vertex="1" connectable="0" parent="sync_resp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Resume normal -->
        <mxCell id="resume_l" value="Resume NORMAL operation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="resume_m" value="Resume NORMAL operation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="510" width="200" height="35" as="geometry" />
        </mxCell>

        <!-- Timeline markers -->
        <mxCell id="tm0" value="t = 0s" style="text;html=1;fontSize=8;fontColor=#999999;align=left;" vertex="1" parent="1">
          <mxGeometry x="910" y="170" width="50" height="15" as="geometry" />
        </mxCell>
        <mxCell id="tm3" value="t = 3s" style="text;html=1;fontSize=8;fontColor=#999999;align=left;" vertex="1" parent="1">
          <mxGeometry x="910" y="210" width="50" height="15" as="geometry" />
        </mxCell>
        <mxCell id="tm5" value="t = 5s" style="text;html=1;fontSize=8;fontColor=#999999;align=left;" vertex="1" parent="1">
          <mxGeometry x="910" y="310" width="50" height="15" as="geometry" />
        </mxCell>
        <mxCell id="tmr" value="t ~ 8s" style="text;html=1;fontSize=8;fontColor=#999999;align=left;" vertex="1" parent="1">
          <mxGeometry x="910" y="470" width="50" height="15" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
