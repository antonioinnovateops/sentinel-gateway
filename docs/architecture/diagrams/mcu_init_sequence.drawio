<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-17" type="device">
  <diagram id="mcu-init" name="MCU Initialization Sequence">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="900" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MCU Initialization and Super-Loop" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Init steps -->
        <mxCell id="s1" value="1. HAL Init&#10;(clocks, GPIO)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2. PWM = 0%&#10;(safe state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="60" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="3. Init Watchdog&#10;(IWDG 2s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="60" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="4. Load Config&#10;(flash + CRC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="60" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="5. Init USB&#10;CDC-ECM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="60" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="6. Init TCP&#10;(lwIP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="60" width="80" height="45" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;" edge="1" source="s2" target="s3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;" edge="1" source="s4" target="s5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e56" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;" edge="1" source="s5" target="s6" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Super-loop -->
        <mxCell id="loop_box" value="7. Super-Loop (infinite)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=3;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="830" height="320" as="geometry" />
        </mxCell>

        <mxCell id="e6loop" style="strokeColor=#666;strokeWidth=2;flowAnimation=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s6" target="loop_box" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="l1" value="Poll lwIP&#10;(tcp_stack)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="Process received&#10;messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="130" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="Check ADC&#10;ready flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="200" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="Send telemetry&#10;(sensor + health)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="200" width="130" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="Feed&#10;Watchdog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="200" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="el12" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="l1" target="l2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el23" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="l2" target="l3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el34" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="l3" target="l4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el45" style="strokeColor=#b85450;strokeWidth=2;flowAnimation=1;" edge="1" source="l4" target="l5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Loop back arrow -->
        <mxCell id="loop_back" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" source="l5" target="l1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="790" y="300" /><mxPoint x="140" y="300" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- Message dispatch detail -->
        <mxCell id="dispatch" value="Message Dispatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;verticalAlign=top;spacingTop=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="760" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="ActuatorCommand&#10;validate + apply PWM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="100" y="375" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="ConfigUpdate&#10;validate + store flash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="260" y="375" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="DiagnosticRequest&#10;get version/config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="420" y="375" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="StateSyncRequest&#10;send full state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="580" y="375" width="140" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
