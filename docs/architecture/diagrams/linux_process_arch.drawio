<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-17" type="device">
  <diagram id="linux-proc" name="Linux Gateway Process Architecture">
    <mxGraphModel dx="900" dy="550" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="900" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Linux Gateway Process Architecture (sentinel-gw)" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- Process container -->
        <mxCell id="proc" value="sentinel-gw (single process)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="820" height="420" as="geometry" />
        </mxCell>

        <!-- Main Thread -->
        <mxCell id="main_thread" value="Main Thread" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="480" height="360" as="geometry" />
        </mxCell>

        <mxCell id="epoll" value="epoll Event Loop&#10;(main dispatcher)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="440" height="45" as="geometry" />
        </mxCell>

        <!-- TCP handlers -->
        <mxCell id="tcp_cmd" value="TCP:5000&#10;Command" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="100" height="45" as="geometry" />
        </mxCell>
        <mxCell id="tcp_tel" value="TCP:5001&#10;Telemetry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="100" height="45" as="geometry" />
        </mxCell>
        <mxCell id="tcp_diag" value="TCP:5002&#10;Diagnostics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="100" height="45" as="geometry" />
        </mxCell>
        <mxCell id="signals" value="Signals&#10;SIGTERM&#10;SIGINT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="200" width="80" height="45" as="geometry" />
        </mxCell>

        <!-- epoll to handlers -->
        <mxCell id="e1" style="strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;" edge="1" source="epoll" target="tcp_cmd" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;" edge="1" source="epoll" target="tcp_tel" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;" edge="1" source="epoll" target="tcp_diag" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="strokeColor=#666;strokeWidth=1;dashed=1;" edge="1" source="epoll" target="signals" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Message dispatch -->
        <mxCell id="dispatch" value="Message Dispatch (by protobuf type)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="440" height="30" as="geometry" />
        </mxCell>

        <!-- Proxies -->
        <mxCell id="sensor" value="Sensor&#10;Proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="85" height="40" as="geometry" />
        </mxCell>
        <mxCell id="actuator" value="Actuator&#10;Proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="320" width="85" height="40" as="geometry" />
        </mxCell>
        <mxCell id="health" value="Health&#10;Monitor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="320" width="85" height="40" as="geometry" />
        </mxCell>
        <mxCell id="config" value="Config&#10;Manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="320" width="85" height="40" as="geometry" />
        </mxCell>

        <!-- protobuf-c -->
        <mxCell id="protobuf" value="protobuf-c (encode / decode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="385" width="440" height="30" as="geometry" />
        </mxCell>

        <!-- Logger Thread -->
        <mxCell id="logger_thread" value="Logger Thread" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="90" width="270" height="360" as="geometry" />
        </mxCell>

        <mxCell id="ring" value="Ring Buffer&#10;(lock-free dequeue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebf7;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="140" width="230" height="40" as="geometry" />
        </mxCell>

        <mxCell id="log_sensor" value="sensor_data.jsonl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="210" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="log_events" value="events.jsonl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="210" width="110" height="35" as="geometry" />
        </mxCell>

        <mxCell id="fsync" value="fsync every 5s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="270" width="150" height="25" as="geometry" />
        </mxCell>

        <mxCell id="rotation" value="Log Rotation&#10;100 MB max, 10 files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="630" y="310" width="150" height="35" as="geometry" />
        </mxCell>

        <!-- Ring buffer flow -->
        <mxCell id="er1" style="strokeColor=#6c8ebf;strokeWidth=2;flowAnimation=1;" edge="1" source="ring" target="log_sensor" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2" style="strokeColor=#6c8ebf;strokeWidth=2;flowAnimation=1;" edge="1" source="ring" target="log_events" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Main to logger -->
        <mxCell id="e_log" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="dispatch" target="ring" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_log_l" value="enqueue" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontColor=#d79b00;" vertex="1" connectable="0" parent="e_log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
