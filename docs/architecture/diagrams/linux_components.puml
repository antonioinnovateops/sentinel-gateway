@startuml linux_components
!theme plain
title Linux Gateway — Component Diagram

skinparam component {
    BackgroundColor<<core>> #85BBF0
    BackgroundColor<<proxy>> #85F0C0
    BackgroundColor<<service>> #F0E085
    BackgroundColor<<lib>> #C0C0C0
}

package "Linux Gateway (sentinel-gw)" {

    component "gateway_core\n(epoll event loop)" <<core>> as core

    package "Proxies" {
        component "sensor_proxy" <<proxy>> as sp
        component "actuator_proxy" <<proxy>> as ap
    }

    package "Services" {
        component "health_monitor" <<service>> as hm
        component "diagnostics\n(TCP:5002)" <<service>> as diag
        component "config_manager" <<service>> as cm
        component "logger\n(JSON Lines)" <<service>> as log
    }

    component "tcp_transport\n(wire framing)" <<lib>> as tcp
    component "protobuf-c" <<lib>> as pb
}

' Core orchestration
core --> sp : dispatch SensorData
core --> hm : dispatch HealthStatus
core --> ap : send commands
core --> diag : handle clients
core --> cm : config ops
core --> tcp : I/O events

' Module dependencies
sp --> pb : decode
sp --> log : write data
ap --> pb : encode/decode
ap --> tcp : send/recv
hm --> tcp : monitor
hm --> log : events
diag --> sp : read cache
diag --> ap : forward cmds
diag --> hm : get status
diag --> log : read entries
cm --> pb : encode
cm --> tcp : send
log --> log : async writer\nthread

' External interfaces
tcp --> [TCP:5000\n(MCU commands)] : client
tcp --> [TCP:5001\n(MCU telemetry)] : server
diag --> [TCP:5002\n(diagnostic CLI)] : server

note bottom of log
  Two log files:
  • sensor_data.jsonl
  • events.jsonl
  Rotation: 100MB × 10 files
  Flush: every 5 seconds
end note
@enduml
