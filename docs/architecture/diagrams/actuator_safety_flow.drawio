<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-17" type="device">
  <diagram id="act-safety" name="Actuator Command Safety Flow">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="1000" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Actuator Command Safety Validation Flow (ASIL-B)" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="input" value="ActuatorCommand&#10;(from TCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="120" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="[1] Decode&#10;Protobuf" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="80" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="[2] Validate&#10;Actuator ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="[3] Check&#10;Rate Limit&#10;(50/sec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="[4] Range&#10;Validation&#10;(min/max)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="80" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="[5] Clamp to&#10;Safety Limits&#10;(e.g. 95% max)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="80" width="110" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s6" value="[6] Write PWM&#10;Register" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebf7;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="200" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s7" value="[7] Readback&#10;Verify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="200" width="100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="s8" value="[8] Send&#10;ActuatorResponse&#10;(OK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="310" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- Error paths -->
        <mxCell id="err_decode" value="Decode Error&#10;FAIL-SAFE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="200" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="err_invalid" value="INVALID&#10;ACTUATOR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="330" y="200" width="100" height="35" as="geometry" />
        </mxCell>

        <mxCell id="err_rate" value="RATE&#10;LIMITED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="470" y="200" width="100" height="35" as="geometry" />
        </mxCell>

        <mxCell id="err_readback" value="Readback Mismatch&#10;FAIL-SAFE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="310" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- Normal flow edges -->
        <mxCell id="e01" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="input" target="s1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
