        <mxCell id="e34" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" source="s4" target="s5" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e56" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s5" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="805" y="160" /><mxPoint x="800" y="160" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e5_6" style="strokeColor=#6c8ebf;strokeWidth=2;flowAnimation=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s7" target="s6" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e78" style="strokeColor=#82b366;strokeWidth=2;flowAnimation=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s7" target="s8" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Error edges -->
        <mxCell id="ee1" style="strokeColor=#b85450;strokeWidth=1;dashed=1;" edge="1" source="s1" target="err_decode" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee1l" value="fail" style="edgeLabel;html=1;fontSize=8;fontColor=#b85450;" vertex="1" connectable="0" parent="ee1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee2" style="strokeColor=#d6b656;strokeWidth=1;dashed=1;" edge="1" source="s2" target="err_invalid" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee2l" value="fail" style="edgeLabel;html=1;fontSize=8;fontColor=#d6b656;" vertex="1" connectable="0" parent="ee2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee3" style="strokeColor=#d6b656;strokeWidth=1;dashed=1;" edge="1" source="s3" target="err_rate" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee3l" value="fail" style="edgeLabel;html=1;fontSize=8;fontColor=#d6b656;" vertex="1" connectable="0" parent="ee3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee4" style="strokeColor=#b85450;strokeWidth=1;dashed=1;" edge="1" source="s7" target="err_readback" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee4l" value="mismatch" style="edgeLabel;html=1;fontSize=8;fontColor=#b85450;" vertex="1" connectable="0" parent="ee4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Write before read label -->
        <mxCell id="wr_note" value="Write then Readback&#10;(detect register corruption)" style="text;html=1;fontSize=8;fontStyle=2;fontColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="168" width="170" height="25" as="geometry" />
        </mxCell>

