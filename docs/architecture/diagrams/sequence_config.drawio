<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-17" type="device">
  <diagram id="seq-config" name="Configuration Update Sequence">
    <mxGraphModel dx="900" dy="500" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="900" pageHeight="450" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Configuration Update Sequence" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="linux_box" value="Linux Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="50" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="mcu_box" value="MCU (STM32U575)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="50" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Config update -->
        <mxCell id="m1" style="rounded=0;strokeColor=#d79b00;strokeWidth=2;flowAnimation=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="195" y="130" as="sourcePoint" /><mxPoint x="655" y="130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m1l" value="[TCP:5000] ConfigUpdate&#10;{channel:0, rate:50Hz}" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontColor=#d79b00;" vertex="1" connectable="0" parent="m1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- MCU validates -->
        <mxCell id="validate" value="1. Validate (1-100 Hz) ✓&#10;2. Apply to timer&#10;3. Store in flash (CRC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="155" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- Config response -->
        <mxCell id="m2" style="rounded=0;strokeColor=#82b366;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="655" y="240" as="sourcePoint" /><mxPoint x="195" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2l" value="[TCP:5000] ConfigResponse {status: OK}" style="edgeLabel;html=1;fontSize=10;fontColor=#82b366;" vertex="1" connectable="0" parent="m2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Now streaming at new rate -->
        <mxCell id="m3" style="rounded=0;strokeColor=#82b366;strokeWidth=2;flowAnimation=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="655" y="300" as="sourcePoint" /><mxPoint x="195" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3l" value="[TCP:5001] SensorData (now at 50Hz)" style="edgeLabel;html=1;fontSize=10;fontStyle=1;fontColor=#82b366;" vertex="1" connectable="0" parent="m3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="Config persists across MCU resets&#10;(stored in flash with CRC-32)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="350" width="250" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
