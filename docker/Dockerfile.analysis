FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    cppcheck \
    clang-tidy \
    lcov \
    python3 \
    python3-pip \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir --break-system-packages \
    junit-xml==1.9 \
    jinja2==3.1.4

RUN useradd -m builder || true
USER builder
WORKDIR /workspace
